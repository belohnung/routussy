# Discord
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id

# Upstream LLM provider (OpenAI-compatible)
UPSTREAM_URL=https://api.z.ai/api/paas/v4
UPSTREAM_API_KEY=your-upstream-key
# Path prefix for upstream endpoints. Defaults to "/v1".
# Set to "" if the base URL already includes the version (e.g. zai's /v4).
UPSTREAM_PREFIX=

# Server
PORT=3000
# Public URL for the proxy (used in /config command output)
PUBLIC_URL=http://localhost:3000

# Database
DATABASE_PATH=routussy.db

# Optional: GitHub token for models.dev pricing fetches (avoids rate limits)
GITHUB_TOKEN=
